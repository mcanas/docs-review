{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DocsReviewConfig",
  "type": "object",
  "required": ["projects", "settings"],
  "additionalProperties": false,
  "properties": {
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "path"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "settings": {
      "type": "object",
      "required": ["file_extensions", "exclude"],
      "additionalProperties": false,
      "properties": {
        "default_project": { "type": "string" },
        "file_extensions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\." },
          "minItems": 1
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
