# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# GitHub repo to review
VITE_REPO_OWNER=your-org
VITE_REPO_NAME=your-docs-repo

# OAuth App Client ID (from your GitHub org's OAuth App — no secret required)
VITE_OAUTH_CLIENT_ID=your-client-id-here

# GitHub API base URL
# For github.com:
VITE_GITHUB_API_URL=https://api.github.com
# For GitHub Enterprise Server (replace hostname):
# VITE_GITHUB_API_URL=https://github.your-company.com/api/v3

# Docs Review project config (YAML, inline)
# Must match the structure of docs-review.config.yml
VITE_DOCS_CONFIG=|
  projects:
    - name: "My Docs"
      path: "docs"
      description: "Project documentation"
  settings:
    default_project: "My Docs"
    file_extensions: [".md", ".mdx"]
    exclude:
      - "**/CHANGELOG.md"
